// Private methods
// Private methods
auto StreamEngine::executeSingleThreaded(std::shared_ptr<ExecutionGraph> graph)
    -> void {
  // Execute operators in topological order with proper error handling and limits
  if (!graph || graph->empty()) {
    return;
  }

  fprintf(stderr, "[StreamEngine] Executing graph with %zu operators\n", graph->size());
  auto operators = graph->getTopologicalOrder();

  // Map to store intermediate results between operators
  std::unordered_map<ExecutionGraph::OperatorId, std::vector<std::unique_ptr<MultiModalMessage>>> intermediate_results;

  // Get configuration limits
  size_t max_messages_per_operator = config_.max_queue_size > 0 ? config_.max_queue_size : 1000;
  auto timeout_duration = config_.timeout;

  for (auto op_id : operators) {
    try {
      auto op = graph->getOperator(op_id);
      if (!op) {
        fprintf(stderr, "[StreamEngine] Warning: Operator %zu not found, skipping\n", static_cast<size_t>(op_id));
        continue;
      }

      // Open the operator with timeout
      auto start_time = std::chrono::steady_clock::now();
      op->open();

      if (op->getType() == OperatorType::kSource) {
        // For source operators, generate messages with limits
        auto source_op = std::dynamic_pointer_cast<SourceOperator>(op);
        if (source_op) {
          std::vector<std::unique_ptr<MultiModalMessage>> messages;

          // Generate messages from source with configurable limit
          size_t message_count = 0;
          while (source_op->hasNext() && message_count < max_messages_per_operator) {
            // Check timeout
            auto current_time = std::chrono::steady_clock::now();
            if (std::chrono::duration_cast<std::chrono::milliseconds>(current_time - start_time) > timeout_duration) {
              fprintf(stderr, "[StreamEngine] Timeout reached for operator %zu\n", static_cast<size_t>(op_id));
              break;
            }

            auto msg = source_op->next();
            if (msg) {
              messages.push_back(std::move(msg));
              message_count++;

              // Update metrics
              metrics_.total_processed_messages++;
            } else {
              break; // No more messages
            }
          }

          if (message_count >= max_messages_per_operator) {
            fprintf(stderr, "[StreamEngine] Message limit (%zu) reached for operator %zu\n",
                    max_messages_per_operator, static_cast<size_t>(op_id));
          }

          intermediate_results[op_id] = std::move(messages);
        }
      } else if (op->getType() == OperatorType::kSink) {
        // For sink operators, process messages from predecessors
        auto predecessors = graph->getPredecessors(op_id);
        std::vector<std::unique_ptr<MultiModalMessage>> input_messages;

        // Collect messages from all predecessors with size limit
        size_t total_messages = 0;
        for (auto pred_id : predecessors) {
          auto it = intermediate_results.find(pred_id);
          if (it != intermediate_results.end()) {
            for (auto& msg : it->second) {
              if (msg && total_messages < max_messages_per_operator) {
                input_messages.push_back(std::move(msg));
                total_messages++;
              }
            }
          }
        }

        // Process each message with the sink
        for (auto& msg : input_messages) {
          if (msg) {
            // Check timeout
            auto current_time = std::chrono::steady_clock::now();
            if (std::chrono::duration_cast<std::chrono::milliseconds>(current_time - start_time) > timeout_duration) {
              fprintf(stderr, "[StreamEngine] Timeout reached while processing messages for operator %zu\n",
                      static_cast<size_t>(op_id));
              break;
            }

            // Create a Response wrapper for the message
            Response response(std::move(msg));

            // Process the message (sink will consume it)
            bool success = op->process(response, 0);
            if (!success) {
              fprintf(stderr, "[StreamEngine] Failed to process message in sink operator %zu\n",
                      static_cast<size_t>(op_id));
            }
          }
        }

        // Sink operators don't produce output
        intermediate_results[op_id] = std::vector<std::unique_ptr<MultiModalMessage>>{};
      } else {
        // For other operators, process messages from predecessors
        auto predecessors = graph->getPredecessors(op_id);
        std::vector<std::unique_ptr<MultiModalMessage>> input_messages;

        // Collect messages from all predecessors with size limit
        size_t total_messages = 0;
        for (auto pred_id : predecessors) {
          auto it = intermediate_results.find(pred_id);
          if (it != intermediate_results.end()) {
            for (auto& msg : it->second) {
              if (msg && total_messages < max_messages_per_operator) {
                input_messages.push_back(std::move(msg));
                total_messages++;
              }
            }
          }
        }

        // Process each message
        std::vector<std::unique_ptr<MultiModalMessage>> output_messages;
        for (auto& msg : input_messages) {
          if (msg) {
            // Check timeout
            auto current_time = std::chrono::steady_clock::now();
            if (std::chrono::duration_cast<std::chrono::milliseconds>(current_time - start_time) > timeout_duration) {
              fprintf(stderr, "[StreamEngine] Timeout reached while processing messages for operator %zu\n",
                      static_cast<size_t>(op_id));
              break;
            }

            // Create a Response wrapper for the message
            Response response(std::move(msg));

            // Process the message
            bool success = op->process(response, 0);

            if (success && response.hasMessage()) {
              // Get the processed message back
              auto processed_msg = response.getMessage();
              if (processed_msg) {
                output_messages.push_back(std::move(processed_msg));
                metrics_.total_processed_messages++;
              }
            } else if (!success) {
              fprintf(stderr, "[StreamEngine] Failed to process message in operator %zu\n",
                      static_cast<size_t>(op_id));
            }
          }
        }

        intermediate_results[op_id] = std::move(output_messages);
      }

      // Close the operator
      op->close();

      // Update processing time metrics
      auto end_time = std::chrono::steady_clock::now();
      auto processing_time = std::chrono::duration_cast<std::chrono::milliseconds>(end_time - start_time);
      updateMetrics(metrics_.total_processed_messages.load(), processing_time.count());

    } catch (const std::exception& e) {
      fprintf(stderr, "[StreamEngine] Error processing operator %zu: %s\n",
              static_cast<size_t>(op_id), e.what());
      // Continue with next operator instead of failing completely
    } catch (...) {
      fprintf(stderr, "[StreamEngine] Unknown error processing operator %zu\n",
              static_cast<size_t>(op_id));
      // Continue with next operator
    }
  }
}

