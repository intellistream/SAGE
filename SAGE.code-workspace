{
  "folders": [
    {
      "name": "SAGE  [meta]",
      "path": "."
    },
    {
      "name": "SAGE-Docs  [docs]",
      "path": "../SAGE-Docs"
    },
    {
      "name": "my-twin  [app]",
      "path": "../sage-faculty-twin"
    },
    {
      "name": "personal-homepage  [profile]",
      "path": "../shuhaozhangtony.github.io"
    },
    {
      "name": "sageVDB  [vdb]",
      "path": "../sageVDB"
    },
    {
      "name": "neuromem  [memory]",
      "path": "../neuromem"
    },
    {
      "name": "vllm-hust  [engine]",
      "path": "../vllm-hust"
    },
    {
      "name": "vllm-ascend-hust  [ascend-plugin]",
      "path": "../vllm-ascend-hust"
    },
    {
      "name": "sage-examples  [examples]",
      "path": "../sage-examples"
    },
    {
      "name": "sage-tutorials  [tutorials]",
      "path": "../sage-tutorials"
    },
    {
      "name": "vamos  [research]",
      "path": "../vamos"
    },
    {
      "name": "vllm-hust-workstation  [ws-app]",
      "path": "../vllm-hust-workstation"
    },
    {
      "path": "../private-materials"
    }
  ],
  "settings": {
    "python.analysis.extraPaths": [
      "${workspaceFolder:SAGE  [meta]}/src",
      "${workspaceFolder:my-twin  [app]}/src",
      "${workspaceFolder:sageVDB  [vdb]}",
      "${workspaceFolder:neuromem  [memory]}",
      "${workspaceFolder:vllm-hust  [engine]}",
      "${workspaceFolder:vllm-ascend-hust  [ascend-plugin]}"
    ],
    "python.testing.pytestArgs": [
      "packages",
      "-v",
      "--tb=short"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "files.exclude": {
      "**/__pycache__": true,
      "**/*.pyc": true,
      "**/*.pyo": true,
      "**/.pytest_cache": true,
      "**/.mypy_cache": true,
      "**/*.egg-info": true,
      "external/SAGE": true,
      "external/vllm-hust": true,
      ".sage/build": true,
      ".sage/cache": true
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/.git": true,
      "external/SAGE": true,
      "external/vllm-hust": true,
      ".sage/build": true,
      ".sage/cache": true,
      "**/dist": true,
      "**/*.egg-info": true,
      "**/.next": true,
      "**/.workstation-deploy": true
    },
    "files.watcherExclude": {
      "**/.git/objects/**": true,
      "**/.git/subtree-cache/**": true,
      "**/node_modules/**": true,
      "**/__pycache__/**": true,
      "**/.pytest_cache/**": true,
      "**/.mypy_cache/**": true,
      "**/.ruff_cache/**": true,
      "**/*.egg-info/**": true,
      "**/dist/**": true,
      "**/build/**": true,
      "**/site/**": true,
      "**/results/**": true,
      "**/external/SAGE/**": true,
      "**/external/vllm-hust/**": true,
      ".sage/build/**": true,
      ".sage/cache/**": true,
      "**/.next/**": true,
      "**/.workstation-deploy/**": true
    },
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.formatOnSave": true
    },
    "ruff.configurationPreference": "filesystemFirst",
    "ruff.configuration": "${workspaceFolder:SAGE  [meta]}/tools/ruff.toml",
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.ignoredRepositories": [
      "/home/shuhao/vamos/external/SAGE",
      "/home/shuhao/vamos/external/vllm-hust"
    ],
    "python-envs.workspaceSearchPaths": []
  },
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "charliermarsh.ruff",
      "ms-toolsai.jupyter",
      "github.copilot",
      "github.copilot-chat",
      "redhat.vscode-yaml",
      "tamasfe.even-better-toml",
      "yzhang.markdown-all-in-one",
      "DavidAnson.vscode-markdownlint"
    ]
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Python: Current File",
        "type": "debugpy",
        "request": "launch",
        "program": "${file}",
        "console": "integratedTerminal",
        "cwd": "${workspaceFolder:SAGE  [meta]}",
        "env": {
          "PYTHONPATH": "${workspaceFolder:SAGE  [meta]}/src"
        }
      },
      {
        "name": "my-twin: Uvicorn (local neuromem)",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
          "sage_faculty_twin.api:app",
          "--host",
          "127.0.0.1",
          "--port",
          "8010",
          "--reload"
        ],
        "console": "integratedTerminal",
        "cwd": "${workspaceFolder:my-twin  [app]}",
        "env": {
          "PYTHONPATH": "${workspaceFolder:my-twin  [app]}/src:${workspaceFolder:SAGE  [meta]}/src:${workspaceFolder:sageVDB  [vdb]}:${workspaceFolder:neuromem  [memory]}"
        }
      },
      {
        "name": "Python: sage-dev CLI",
        "type": "debugpy",
        "request": "launch",
        "module": "sage.tools.cli",
        "args": [
          "--help"
        ],
        "console": "integratedTerminal",
        "cwd": "${workspaceFolder:SAGE  [meta]}"
      },
      {
        "name": "Pytest: Current File",
        "type": "debugpy",
        "request": "launch",
        "module": "pytest",
        "args": [
          "${file}",
          "-v",
          "--tb=short"
        ],
        "console": "integratedTerminal",
        "cwd": "${workspaceFolder:SAGE  [meta]}"
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Install SAGE (dev)",
        "type": "shell",
        "command": "./quickstart.sh --dev --yes",
        "group": "build",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:SAGE  [meta]}"
        }
      },
      {
        "label": "Run Tests",
        "type": "shell",
        "command": "sage-dev project test --coverage",
        "group": "test",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:SAGE  [meta]}"
        }
      },
      {
        "label": "Run vLLM Tests (engine)",
        "type": "shell",
        "command": "test -x .venv/bin/python && .venv/bin/python -m pytest tests -v || (echo 'Missing vllm-hust .venv. Run uv venv --python 3.12 and install deps first.' && exit 1)",
        "group": "test",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:vllm-hust  [engine]}"
        }
      },
      {
        "label": "Run vLLM Ascend UT",
        "type": "shell",
        "command": "pytest -sv tests/ut/",
        "group": "test",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:vllm-ascend-hust  [ascend-plugin]}"
        }
      },
      {
        "label": "Lint vLLM Ascend",
        "type": "shell",
        "command": "ruff check vllm_ascend/",
        "group": "test",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:vllm-ascend-hust  [ascend-plugin]}"
        }
      },
      {
        "label": "Code Quality Check",
        "type": "shell",
        "command": "sage-dev quality check --all-files",
        "group": "test",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:SAGE  [meta]}"
        }
      },
      {
        "label": "Code Quality Fix",
        "type": "shell",
        "command": "sage-dev quality fix --all-files",
        "group": "build",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:SAGE  [meta]}"
        }
      },
      {
        "label": "Build Docs",
        "type": "shell",
        "command": "mkdocs build",
        "group": "build",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:SAGE-Docs  [docs]}"
        }
      },
      {
        "label": "Serve Docs",
        "type": "shell",
        "command": "mkdocs serve",
        "group": "build",
        "problemMatcher": [],
        "isBackground": true,
        "options": {
          "cwd": "${workspaceFolder:SAGE-Docs  [docs]}"
        }
      },
      {
        "label": "Run my-twin (local neuromem)",
        "type": "shell",
        "command": "PYTHONPATH=${workspaceFolder:my-twin  [app]}/src:${workspaceFolder:SAGE  [meta]}/src:${workspaceFolder:sageVDB  [vdb]}:${workspaceFolder:neuromem  [memory]} uvicorn sage_faculty_twin.api:app --host 127.0.0.1 --port 8010 --reload",
        "group": "build",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:my-twin  [app]}"
        }
      },
      {
        "label": "Sync Homepage Knowledge (offline)",
        "type": "shell",
        "command": "PYTHONPATH=${workspaceFolder:my-twin  [app]}/src:${workspaceFolder:SAGE  [meta]}/src:${workspaceFolder:neuromem  [memory]} python -m sage_faculty_twin.knowledge_import --homepage-dir ${workspaceFolder:personal-homepage  [profile]} --knowledge-dir ${workspaceFolder:my-twin  [app]}/data/knowledge_base --knowledge-backend neuromem",
        "group": "build",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder:my-twin  [app]}"
        }
      }
    ]
  }
}