#!/bin/bash
# Pre-push hook — enforce the main-only branch policy locally.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_ref" = "refs/heads/main" ] || [ "$remote_ref" = "refs/heads/main" ]; then
        echo -e "${RED}✗ Direct push to main is forbidden${NC}"
        echo -e "${YELLOW}  Use a feature/* branch and merge via pull request into main.${NC}"
        exit 1
    fi
done

exit 0
exit 0
