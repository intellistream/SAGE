#!/usr/bin/env bash
# Pre-commit hook — delegates to pre-commit framework (all checks in .pre-commit-config.yaml)
#
# Installed automatically by:
#   ./quickstart.sh          (recommended)
#   pre-commit install       (equivalent, canonical command)
#
# ⚠️  Do NOT `cp` this file manually to .git/hooks/; use the commands above.

if command -v pre-commit >/dev/null 2>&1; then
    exec pre-commit hook-impl \
        --config=.pre-commit-config.yaml \
        --hook-type=pre-commit \
        --hook-dir "$(cd "$(dirname "$0")" && pwd)" \
        -- "$@"
else
    echo "pre-commit not found. Run: pip install pre-commit && pre-commit install" >&2
    exit 1
fi
